# Profile: "minimal" (default) or "full".
# minimal: mock LLM, SQLite, calculator only, no network. Safe offline demo.
# full:    auto-switches to ollama backend + enables LLM-as-judge. Requires
#          `ollama serve` locally (and, for cloud models, `ollama signin`).
AGENTOS_PROFILE=minimal

# LLM backend: "mock" | "ollama"
# When profile=full and backend is left at mock, we auto-upgrade to ollama.
AGENTOS_LLM_BACKEND=mock
AGENTOS_OLLAMA_BASE_URL=http://localhost:11434
# Cloud model via the Ollama daemon. `ollama signin` + `ollama pull` first.
AGENTOS_OLLAMA_MODEL=gemma4:31b-cloud
# Only needed when the Ollama endpoint is behind a bearer-auth proxy.
# Cloud-model auth through the local daemon does NOT need this.
AGENTOS_OLLAMA_API_KEY=

# Storage
AGENTOS_DB_PATH=./data/agentos.db
AGENTOS_PROMPT_VERSION=react-context-v1

# Feature flags (ablation switches)
AGENTOS_ENABLE_MEMORY=true
AGENTOS_ENABLE_PLANNER=true
AGENTOS_ENABLE_TOOLS=true
AGENTOS_ENABLE_REFLECTION=true
# LLM-as-judge for live runs. Off in minimal; on in full.
AGENTOS_ENABLE_LLM_JUDGE=false
AGENTOS_ENABLE_OTEL=false

# Agent loop limits
AGENTOS_MAX_STEPS=4
AGENTOS_EVAL_PASS_THRESHOLD=0.6
AGENTOS_CONTEXT_CHAR_BUDGET=8000
AGENTOS_MEMORY_SEARCH_K=8
AGENTOS_MEMORY_MIN_SALIENCE=0.15
AGENTOS_WORKING_MEMORY_TTL_SECONDS=3600
AGENTOS_EPISODIC_MEMORY_TTL_SECONDS=1209600

# Optional tool integrations (off by default)
AGENTOS_ENABLE_HTTP_FETCH=true
AGENTOS_ENABLE_TAVILY=false
AGENTOS_TAVILY_API_KEY=

# Optional observability export
AGENTOS_OTEL_SERVICE_NAME=agentos-core
AGENTOS_OTEL_EXPORTER_OTLP_ENDPOINT=
